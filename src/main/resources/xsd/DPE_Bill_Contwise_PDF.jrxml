    <parameter name="containerNo" class="java.lang.String"/>
    <queryString>
        <![CDATA[select container_no,gate_in_date_time,admission_chit_no,agent_customer_name,
boe_no,ten_delivery_date,act_delivery_date,cfs_no,cfs_date,
service_type_cd,service_name,service_from_date,service_to_date,
rate,amount,cgst,sgst,tds_amt,total_val,payment_no,payment_date,
service_remarks,sap_ref_no,p2prequestid,status,max_gate_in_time,
ref_tran_no,agent_cd,
sum_total_cont_word as value_in_word
from dpe_bill_as_payment_vw
where container_no = $P{containerNo}
order by cfs_date]]>
    </queryString>
