    <queryString>
        <![CDATA[select container_no,gate_in_date_time,admission_chit_no,agent_customer_name,
boe_no,ten_delivery_date,act_delivery_date,cfs_no,cfs_date,
service_type_cd,service_name,service_from_date,service_to_date,
